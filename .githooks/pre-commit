#!/usr/bin/env bash
set -euo pipefail

cd "$(git rev-parse --show-toplevel)/ows"

echo "Checking cargo fmt..."
if ! cargo fmt --all -- --check 2>&1; then
  echo ""
  echo "ERROR: cargo fmt found formatting issues."
  echo "Run 'cargo fmt --all' in ows/ to fix, then re-stage and commit."
  exit 1
fi

echo "Checking cargo clippy..."
if ! cargo clippy --workspace -- -D warnings 2>&1; then
  echo ""
  echo "ERROR: cargo clippy found warnings."
  echo "Fix the issues above, then re-stage and commit."
  exit 1
fi

echo "Verifying Cargo.lock files are up to date..."
ROOT="$(git rev-parse --show-toplevel)"
for dir in ows bindings/node bindings/python; do
  if ! cargo metadata --locked --format-version 1 --manifest-path "$ROOT/$dir/Cargo.toml" > /dev/null 2>&1; then
    echo ""
    echo "ERROR: $dir/Cargo.lock is out of date."
    echo "Run 'cargo check' in $dir/ to update it, then re-stage and commit."
    exit 1
  fi
done

echo "Pre-commit checks passed."
